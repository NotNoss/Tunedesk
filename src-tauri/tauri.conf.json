{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mpv"]
  },
  "productName": "tunedesk",
  "mainBinaryName": "tunedesk",
  "version": "1.0.0",
  "identifier": "com.noss.tunedesk",
  "plugins": {},
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Tunedesk",
        "width": 800,
        "height": 600,
        "useHttpsScheme": true,
        "decorations": false
      }
    ]
  }
}